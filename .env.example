# OpenAI (required)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Polymarket CLOB API (optional — for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Signing private key; never commit
POLYMARKET_PRIVATE_KEY=
# 0x address holding funds
POLYMARKET_FUNDER_ADDRESS=
# 0=EOA; use the value required by your wallet type
POLYMARKET_SIGNATURE_TYPE=
# Must exactly equal POLYMARKET_FUNDER_ADDRESS
LIVE_TRADING_ACK=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — channel monitoring and edge-trade alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=
# Destination user/group/channel for edge-trade notifications
TELEGRAM_ALERT_CHAT_ID=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100
MAX_OPEN_EXPOSURE_USD=100
MAX_SLIPPAGE_BPS=50
EDGE_THRESHOLD=0.10

# V2 Settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
MATERIALITY_THRESHOLD=0.6
SPEED_TARGET_SECONDS=5
MAX_NEWS_AGE_SECONDS=300
# Empty means live signals are rejected. Explicitly allow only reviewed sources.
LIVE_ALLOWED_NEWS_SOURCES=rss
