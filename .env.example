# OpenAI (required)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Polymarket CLOB V2 (optional — required only for live trading)
# The V2 SDK derives its CLOB credentials from this signing key.
POLYMARKET_PRIVATE_KEY=
# Deposit/funder wallet holding pUSD
POLYMARKET_FUNDER_ADDRESS=
# Use the V2 signature type required by your wallet (0/1/2/3).
POLYMARKET_SIGNATURE_TYPE=
# Must exactly equal POLYMARKET_FUNDER_ADDRESS
LIVE_TRADING_ACK=

# Source definitions live in sources.json. Point to a private copy if desired.
SOURCE_CONFIG_PATH=sources.json

# X API v2 (optional — needed for enabled twitter profiles)
TWITTER_BEARER_TOKEN=

# Telegram Bot (optional — needed for enabled telegram profiles and alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100
MAX_OPEN_EXPOSURE_USD=100
MAX_SLIPPAGE_BPS=50
EDGE_THRESHOLD=0.10
MIN_SOURCE_RELEVANCE=0.65
CORROBORATION_WINDOW_SECONDS=900
MARKET_MATCH_THRESHOLD=0.18
MARKET_SEARCH_QUERIES=Israel,Netanyahu,Gaza,Hamas,Hezbollah,Iran
LIVE_SOURCE_ALLOWLIST=

# Market and classification settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
MATERIALITY_THRESHOLD=0.6
SPEED_TARGET_SECONDS=5
